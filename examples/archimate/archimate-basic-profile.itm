%metadata
{
  title: ITM ArchiMate Basic Profile
  version: 0.1.0
  status: draft
  defaultNamespace: archimate
  profile: itm.ea.archimate-basic
  description: Reusable ITM package declaring ArchiMate 3.2 element types, relationship types, validation rules, styles, and production viewpoints.
}

%package archimate_profile
{
  version: 0.1.0
  namespace: archimate
  profileKind: semantic-model-profile
  targetStandard: ArchiMate 3.2
  scope: basic-production-profile
  activation:
    - archimate_profile.types
    - archimate_profile.relationships
    - archimate_profile.rules
    - archimate_profile.styles
    - archimate_profile.viewpoints
}

%namespace archimate https://www.opengroup.org/archimate/3.2
%namespace itm https://example.org/itm
%namespace prov https://www.w3.org/ns/prov
%namespace layout https://example.org/itm/layout

%require itm.core ^0.1.0
%require itm.type-hierarchy ^0.1.0
%require itm.relationship-identity ^0.1.0
%require itm.validation ^0.1.0
%require itm.viewpoint ^0.1.0
%require itm.graph-model ^0.1.0
%require itm.roundtrip.meta ^0.1.0
%require archimate.rules ^0.1.0
%require archimate.exchange ^0.1.0

%entitytype archimate::Concept
{
  abstract: true
  conceptKind: concept
}

%entitytype archimate::Element
