%entitytype bpmn::TerminateEventDefinition
{
  extends:
    - "bpmn::EventDefinition"
  exportType: terminateEventDefinition
}

%entitytype bpmn::TimerEventDefinition
{
  extends:
    - "bpmn::EventDefinition"
  exportType: timerEventDefinition
