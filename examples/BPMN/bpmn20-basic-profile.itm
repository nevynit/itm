%entitytype bpmn::ExclusiveGateway
{
  extends:
    - "bpmn::Gateway"
  exportType: exclusiveGateway
  recommendedAttributes:
    - gatewayDirection
    - default
}

%entitytype bpmn::InclusiveGateway
{
  extends:
    - "bpmn::Gateway"
  exportType: inclusiveGateway
  recommendedAttributes:
    - gatewayDirection
    - default
}

%entitytype bpmn::ParallelGateway
{
  extends:
    - "bpmn::Gateway"
  exportType: parallelGateway
  recommendedAttributes:
