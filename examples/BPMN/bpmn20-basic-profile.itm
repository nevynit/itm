%entitytype bpmn::ErrorEventDefinition
{
  extends:
    - "bpmn::EventDefinition"
  exportType: errorEventDefinition
  recommendedAttributes:
    - errorRef
}

%entitytype bpmn::EscalationEventDefinition
{
  extends:
    - "bpmn::EventDefinition"
  exportType: escalationEventDefinition
  recommendedAttributes:
    - escalationRef
}

%entitytype bpmn::LinkEventDefinition
{
  extends:
    - "bpmn::EventDefinition"
  exportType: linkEventDefinition
  requiredAttributes:
    - name
}

%entitytype bpmn::MessageEventDefinition
{
  extends:
    - "bpmn::EventDefinition"
  exportType: messageEventDefinition
  recommendedAttributes:
