%entitytype bpmn::DataObject
{
  extends:
    - "bpmn::DataElement"
  exportType: dataObject
  recommendedAttributes:
    - itemSubjectRef
    - isCollection
}

%entitytype bpmn::DataObjectReference
{
  extends:
    - "bpmn::FlowElement"
  exportType: dataObjectReference
  requiredAttributes:
    - dataObjectRef
}

%entitytype bpmn::DataStore
{
  extends:
    - "bpmn::RootElement"
  exportType: dataStore
  recommendedAttributes:
    - capacity
    - isUnlimited
    - itemSubjectRef
}

%entitytype bpmn::DataStoreReference
{
  extends:
    - "bpmn::FlowElement"
  exportType: dataStoreReference
  requiredAttributes:
    - dataStoreRef
}

%entitytype bpmn::Property
{
  extends:
    - "bpmn::BaseElement"
  exportType: property
  recommendedAttributes:
    - itemSubjectRef
}

%entitytype bpmn::DataInput
{
  extends:
    - "bpmn::BaseElement"
  exportType: dataInput
  recommendedAttributes:
    - itemSubjectRef
    - isCollection
}

%entitytype bpmn::DataOutput
{
  extends:
    - "bpmn::BaseElement"
  exportType: dataOutput
  recommendedAttributes:
    - itemSubjectRef
    - isCollection
}

%entitytype bpmn::InputOutputSpecification
{
  extends:
    - "bpmn::BaseElement"
  exportType: ioSpecification
}

%entitytype bpmn::InputSet
{
  extends:
    - "bpmn::BaseElement"
  exportType: inputSet
}

%entitytype bpmn::OutputSet
{
  extends:
    - "bpmn::BaseElement"
  exportType: outputSet
}

%entitytype bpmn::ResourceRole
{
  extends:
    - "bpmn::BaseElement"
  exportType: resourceRole
}

%entitytype bpmn::Performer
{
