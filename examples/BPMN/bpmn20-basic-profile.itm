  exportType: humanPerformer
}

%entitytype bpmn::PotentialOwner
{
  extends:
    - "bpmn::HumanPerformer"
  exportType: potentialOwner
}

%entitytype bpmn::LaneSet
{
  extends:
    - "bpmn::BaseElement"
  exportType: laneSet
