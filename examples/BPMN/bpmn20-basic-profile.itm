%metadata
{
  title: ITM BPMN 2.0 Basic Profile
  version: 0.1.0
  status: draft
  defaultNamespace: bpmn
  profile: itm.process.bpmn20-basic
  description: Reusable ITM package declaring BPMN 2.0/2.0.2 element types, relationship types, validation rules, styles, and production viewpoints.
}

%package bpmn20_profile
{
  version: 0.1.0
  namespace: bpmn
  profileKind: semantic-process-profile
  targetStandard: BPMN 2.0.2
  scope: basic-production-profile
  activation:
    - bpmn20_profile.types
    - bpmn20_profile.relationships
    - bpmn20_profile.rules
    - bpmn20_profile.styles
    - bpmn20_profile.viewpoints
}

%namespace bpmn https://www.omg.org/spec/BPMN/20100524/MODEL
%namespace bpmndi https://www.omg.org/spec/BPMN/20100524/DI
%namespace dc https://www.omg.org/spec/DD/20100524/DC
%namespace di https://www.omg.org/spec/DD/20100524/DI
%namespace itm https://example.org/itm
%namespace prov https://www.w3.org/ns/prov
%namespace layout https://example.org/itm/layout

%require itm.core ^0.1.0
%require itm.type-hierarchy ^0.1.0
%require itm.relationship-identity ^0.1.0
%require itm.validation ^0.1.0
%require itm.graph-model ^0.1.0
%require itm.roundtrip.meta ^0.1.0
%require itm.viewpoint ^0.1.0
%require bpmn.rules ^0.1.0
%require bpmn.xml ^0.1.0
%require bpmn.di ^0.1.0

# -----------------------------------------------------------------------------
# Abstract type hierarchy
# -----------------------------------------------------------------------------

%entitytype bpmn::BaseElement
{
  abstract: true
  description: Common superclass for BPMN elements that can carry id, documentation, extension elements, and extension attributes.
  requiredAttributes:
    - id
}

%entitytype bpmn::RootElement
{
  abstract: true
  extends:
    - "bpmn::BaseElement"
  description: BPMN element that may appear under definitions as reusable model content.
}

%entitytype bpmn::CallableElement
{
  abstract: true
  extends:
    - "bpmn::RootElement"
  description: A reusable process, choreography, or global task that can be called.
}

%entitytype bpmn::FlowElement
{
  abstract: true
  extends:
    - "bpmn::BaseElement"
  description: Element that belongs to a flowElements collection in a Process, SubProcess, or Choreography.
}

%entitytype bpmn::FlowNode
{
  abstract: true
  extends:
    - "bpmn::FlowElement"
  description: Element that can be the source or target of a sequence flow.
}

%entitytype bpmn::Event
{
  abstract: true
  extends:
    - "bpmn::FlowNode"
  bpmnKind: event
}

%entitytype bpmn::CatchEvent
{
  abstract: true
  extends:
    - "bpmn::Event"
  bpmnKind: catchEvent
}

%entitytype bpmn::ThrowEvent
{
  abstract: true
  extends:
    - "bpmn::Event"
  bpmnKind: throwEvent
}

%entitytype bpmn::Activity
{
  abstract: true
  extends:
    - "bpmn::FlowNode"
  bpmnKind: activity
  commonAttributes:
    - isForCompensation
    - startQuantity
    - completionQuantity
    - loopCharacteristics
}

%entitytype bpmn::TaskBase
{
  abstract: true
  extends:
    - "bpmn::Activity"
  bpmnKind: task
}

%entitytype bpmn::Gateway
{
  abstract: true
  extends:
    - "bpmn::FlowNode"
  bpmnKind: gateway
}

%entitytype bpmn::ConnectingObject
{
  abstract: true
  extends:
    - "bpmn::BaseElement"
  bpmnKind: connectingObject
}

%entitytype bpmn::Artifact
{
  abstract: true
  extends:
    - "bpmn::BaseElement"
  bpmnKind: artifact
}

%entitytype bpmn::DataElement
{
  abstract: true
  extends:
    - "bpmn::FlowElement"
  bpmnKind: data
}

%entitytype bpmn::EventDefinition
{
  abstract: true
  extends:
    - "bpmn::RootElement"
  description: Event definition referenced by or embedded in an event.
}

%entitytype bpmn::InteractionNode
{
  abstract: true
  extends:
    - "bpmn::BaseElement"
  description: Element that can participate in message flows or conversation links.
}

# -----------------------------------------------------------------------------
# Definitions and root elements
# -----------------------------------------------------------------------------

%entitytype bpmn::Definitions
{
  extends:
    - "bpmn::BaseElement"
  exportType: definitions
  requiredAttributes:
    - targetNamespace
  recommendedAttributes:
    - exporter
    - exporterVersion
}

%entitytype bpmn::Import
{
  extends:
    - "bpmn::BaseElement"
  exportType: import
  requiredAttributes:
    - importType
    - location
    - namespace
}

%entitytype bpmn::Extension
{
  extends:
    - "bpmn::BaseElement"
  exportType: extension
  recommendedAttributes:
    - mustUnderstand
}

%entitytype bpmn::Process
{
  extends:
    - "bpmn::CallableElement"
  exportType: process
  recommendedAttributes:
    - processType
    - isExecutable
  allowedChildren:
    - bpmn::FlowElement
    - bpmn::Artifact
    - bpmn::LaneSet
    - bpmn::Property
    - bpmn::ResourceRole
}

%entitytype bpmn::Collaboration
{
  extends:
    - "bpmn::RootElement"
  exportType: collaboration
  allowedChildren:
    - bpmn::Participant
    - bpmn::MessageFlow
    - bpmn::ConversationNode
    - bpmn::Artifact
    - bpmn::CorrelationKey
}

%entitytype bpmn::Choreography
{
  extends:
    - "bpmn::Collaboration"
    - "bpmn::CallableElement"
  exportType: choreography
}

%entitytype bpmn::GlobalTask
{
  extends:
    - "bpmn::CallableElement"
  exportType: globalTask
}

%entitytype bpmn::GlobalBusinessRuleTask
{
  extends:
    - "bpmn::GlobalTask"
  exportType: globalBusinessRuleTask
  recommendedAttributes:
    - implementation
}

%entitytype bpmn::GlobalManualTask
{
  extends:
    - "bpmn::GlobalTask"
  exportType: globalManualTask
}

%entitytype bpmn::GlobalScriptTask
{
  extends:
    - "bpmn::GlobalTask"
  exportType: globalScriptTask
  recommendedAttributes:
    - scriptLanguage
}

%entitytype bpmn::GlobalUserTask
{
  extends:
    - "bpmn::GlobalTask"
  exportType: globalUserTask
  recommendedAttributes:
    - implementation
}

%entitytype bpmn::GlobalChoreographyTask
{
  extends:
    - "bpmn::Choreography"
  exportType: globalChoreographyTask
}

%entitytype bpmn::Message
{
  extends:
    - "bpmn::RootElement"
  exportType: message
  recommendedAttributes:
    - itemRef
}

%entitytype bpmn::Error
{
  extends:
    - "bpmn::RootElement"
  exportType: error
  recommendedAttributes:
    - errorCode
    - structureRef
}

%entitytype bpmn::Escalation
{
  extends:
    - "bpmn::RootElement"
  exportType: escalation
  recommendedAttributes:
    - escalationCode
    - structureRef
}

%entitytype bpmn::Signal
{
  extends:
    - "bpmn::RootElement"
  exportType: signal
  recommendedAttributes:
    - structureRef
}

%entitytype bpmn::ItemDefinition
{
  extends:
    - "bpmn::RootElement"
  exportType: itemDefinition
  recommendedAttributes:
    - itemKind
    - structureRef
    - isCollection
}

%entitytype bpmn::Interface
{
  extends:
    - "bpmn::RootElement"
  exportType: interface
  recommendedAttributes:
    - implementationRef
}

%entitytype bpmn::Operation
{
  extends:
    - "bpmn::BaseElement"
  exportType: operation
  recommendedAttributes:
    - implementationRef
    - inMessageRef
    - outMessageRef
}

%entitytype bpmn::Resource
{
  extends:
    - "bpmn::RootElement"
  exportType: resource
}

%entitytype bpmn::ResourceParameter
{
  extends:
    - "bpmn::BaseElement"
  exportType: resourceParameter
  recommendedAttributes:
    - isRequired
    - type
}

%entitytype bpmn::Category
{
  extends:
    - "bpmn::RootElement"
  exportType: category
}

%entitytype bpmn::CategoryValue
{
  extends:
    - "bpmn::BaseElement"
  exportType: categoryValue
  recommendedAttributes:
    - value
}

%entitytype bpmn::CorrelationProperty
{
  extends:
    - "bpmn::RootElement"
  exportType: correlationProperty
  recommendedAttributes:
    - type
}

%entitytype bpmn::CorrelationKey
{
  extends:
    - "bpmn::BaseElement"
  exportType: correlationKey
}

# -----------------------------------------------------------------------------
# Events
# -----------------------------------------------------------------------------

%entitytype bpmn::StartEvent
{
  extends:
    - "bpmn::CatchEvent"
  exportType: startEvent
  recommendedAttributes:
