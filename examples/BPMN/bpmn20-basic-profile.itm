    - timeCycle
}

# -----------------------------------------------------------------------------
# Activities and tasks
# -----------------------------------------------------------------------------

%entitytype bpmn::Task
{
  extends:
    - "bpmn::TaskBase"
  exportType: task
  recommendedAttributes:
    - owner
}

%entitytype bpmn::BusinessRuleTask
{
  extends:
    - "bpmn::TaskBase"
  exportType: businessRuleTask
  recommendedAttributes:
    - implementation
    - owner
}

%entitytype bpmn::ManualTask
{
  extends:
    - "bpmn::TaskBase"
  exportType: manualTask
  recommendedAttributes:
    - owner
}

%entitytype bpmn::ReceiveTask
{
  extends:
    - "bpmn::TaskBase"
  exportType: receiveTask
  recommendedAttributes:
    - messageRef
    - operationRef
    - instantiate
    - owner
}

%entitytype bpmn::ScriptTask
{
  extends:
    - "bpmn::TaskBase"
  exportType: scriptTask
  recommendedAttributes:
    - scriptFormat
    - script
    - owner
}

%entitytype bpmn::SendTask
{
  extends:
    - "bpmn::TaskBase"
  exportType: sendTask
  recommendedAttributes:
    - messageRef
    - operationRef
    - owner
}

%entitytype bpmn::ServiceTask
{
  extends:
    - "bpmn::TaskBase"
  exportType: serviceTask
  recommendedAttributes:
    - implementation
    - operationRef
    - owner
}

%entitytype bpmn::UserTask
{
  extends:
    - "bpmn::TaskBase"
  exportType: userTask
  recommendedAttributes:
    - implementation
    - owner
}

%entitytype bpmn::SubProcess
{
  extends:
    - "bpmn::Activity"
  exportType: subProcess
  allowedChildren:
    - bpmn::FlowElement
    - bpmn::Artifact
    - bpmn::LaneSet
}

%entitytype bpmn::AdHocSubProcess
{
  extends:
    - "bpmn::SubProcess"
  exportType: adHocSubProcess
  recommendedAttributes:
    - completionCondition
    - ordering
    - cancelRemainingInstances
}

%entitytype bpmn::Transaction
{
  extends:
    - "bpmn::SubProcess"
  exportType: transaction
  recommendedAttributes:
    - protocol
    - method
}

%entitytype bpmn::CallActivity
{
  extends:
    - "bpmn::Activity"
  exportType: callActivity
  requiredAttributes:
    - calledElementRef
}

