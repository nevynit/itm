}

%entitytype bpmn::IntermediateThrowEvent
{
  extends:
    - "bpmn::ThrowEvent"
  exportType: intermediateThrowEvent
  recommendedAttributes:
    - eventDefinition
}

%entitytype bpmn::EndEvent
{
  extends:
    - "bpmn::ThrowEvent"
  exportType: endEvent
  recommendedAttributes:
    - eventDefinition
}

%entitytype bpmn::BoundaryEvent
{
  extends:
    - "bpmn::CatchEvent"
  exportType: boundaryEvent
  requiredAttributes:
